APP_NAME=Sage AI
ENVIRONMENT=production
USE_REMOTE_STACK=false

# Database
POSTGRES_DB=sage
POSTGRES_USER=sage
POSTGRES_PASSWORD=sage
DATABASE_URL=postgresql+psycopg://sage:sage@postgres:5432/sage
DATABASE_URL_LOCAL=postgresql+psycopg://sage:sage@localhost:5432/sage

# Auth
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ISSUER=sage-ai
JWT_AUDIENCE=sage-users

# Admin bootstrap
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=SageAdmin2026!
INITIAL_ADMIN_FULL_NAME=Sage

# LLM - Ollama on the remote Tailnet host
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CLASSIFY_MODEL=llama3.1:8b
OLLAMA_REMOTE_HOST_ALIAS=llm-server
OLLAMA_REMOTE_HOST_IP=100.70.5.76
ANTHROPIC_API_KEY=

# Vector store
QDRANT_URL=http://qdrant:6333

# WhatsApp / WAHA
WHATSAPP_GATEWAY_URL=http://waha:3000
WHATSAPP_INSTANCE=default
EVOLUTION_API_KEY=change-me-wa
WHATSAPP_GATEWAY_TOKEN=change-me-wa
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=change-me-waha
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=change-me-waha
WAHA_START_SESSION=default

# Email
EMAIL_FROM=sage@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Teams
MS_TEAMS_WEBHOOK_URL=

# Microsoft Graph
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_USER_ID=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://100.120.126.117,http://100.120.126.117:5173

