<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sage.ai.stack</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/Assistant/Library/Application Support/Executive-Assistant/start_assistant_stack.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/Assistant/Library/Logs/Executive-Assistant/launchd-stack.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/Assistant/Library/Logs/Executive-Assistant/launchd-stack.err.log</string>
</dict>
</plist>