<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sage.ai.watchdog</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/Assistant/Library/Application Support/Executive-Assistant/watchdog_assistant_stack.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>StandardOutPath</key>
  <string>/Users/Assistant/Library/Logs/Executive-Assistant/launchd-watchdog.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/Assistant/Library/Logs/Executive-Assistant/launchd-watchdog.err.log</string>
</dict>
</plist>